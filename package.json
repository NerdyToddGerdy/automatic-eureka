{
  "name": "image-tagger",
  "version": "2.0.0",
  "description": "Image Vault - RPG Asset Manager",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "package-mac": "electron-builder --mac",
    "package-win": "electron-builder --win",
    "package-linux": "electron-builder --linux"
  },
  "author": "Todd Gerdy",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.imagetagger.app",
    "productName": "Image Vault",
    "files": [
      "electron/**/*",
      "static/**/*",
      "templates/**/*",
      "app.py",
      "database.py",
      "metadata.py",
      "scanner.py",
      "drive_client.py",
      "drive_sync.py",
      "cache.py",
      "file_utils.py",
      "config.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
